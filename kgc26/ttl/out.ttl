@prefix foaf: <http://xmlns.com/foaf/0.1/> .

author:adams    a :Author ; 
    :birthYear "1952"^^xsd:long ;
    :deathYear "2001"^^xsd:long ;
    :hasAdaptation adaptation:hhgtg_film, adaptation:hhgtg_radio ;
    :hasEra :ModernEra ;
    :nationality country:UK ;
    :wrote book:hhgtg, book:restaurant ;
    rdfs:label "Douglas Adams" .

author:asimov    a :Author ; 
    :birthYear "1920"^^xsd:long ;
    :deathYear "1992"^^xsd:long ;
    :hasAdaptation adaptation:foundation_tv ;
    :hasEra :GoldenAge ;
    :nationality country:US ;
    :wrote book:foundation, book:foundation_empire, book:second_foundation ;
    rdfs:label "Isaac Asimov" .

author:herbert    a :Author ; 
    :birthYear "1920"^^xsd:long ;
    :deathYear "1986"^^xsd:long ;
    :hasAdaptation adaptation:dune_lynch, adaptation:dune_villeneuve ;
    :hasEra :NewWave ;
    :nationality country:US ;
    :wrote book:children_of_dune, book:dune, book:dune_messiah ;
    rdfs:label "Frank Herbert" .

author:le_guin    a :Author ; 
    :birthYear "1929"^^xsd:long ;
    :deathYear "2018"^^xsd:long ;
    :hasAdaptation adaptation:earthsea_ghibli ;
    :hasEra :NewWave ;
    :nationality country:US ;
    :wrote book:tombs_of_atuan, book:wizard_earthsea ;
    rdfs:label "Ursula K. Le Guin" .

author:pratchett    a :Author ; 
    :birthYear "1948"^^xsd:long ;
    :deathYear "2015"^^xsd:long ;
    :hasEra :ModernEra ;
    :nationality country:UK ;
    :wrote book:colour_of_magic, book:guards_guards, book:mort ;
    rdfs:label "Terry Pratchett" .

author:tolkien    a :Author ; 
    :birthYear "1892"^^xsd:long ;
    :deathYear "1973"^^xsd:long ;
    :hasAdaptation adaptation:fellowship_film, adaptation:hobbit_film, adaptation:return_king_film, adaptation:two_towers_film ;
    :hasEra :Modernist ;
    :nationality country:UK ;
    :wrote book:fellowship, book:hobbit, book:return_king, book:two_towers ;
    rdfs:label "J.R.R. Tolkien" .

